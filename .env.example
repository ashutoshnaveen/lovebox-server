# Shared passcode for the sender web page
LOVEBOX_PASSCODE=change-me-to-a-strong-secret

# Per-device secret keys (one per deviceId)
# Format: DEVICE_KEY_{deviceId in uppercase with hyphens replaced by underscores}
DEVICE_KEY_LOVEBOX_001=change-me-to-a-random-device-secret

# Netlify Blobs context is injected automatically by Netlify CLI and production.
# Do not set this manually unless you know what you are doing.
# NETLIFY_BLOBS_CONTEXT=
